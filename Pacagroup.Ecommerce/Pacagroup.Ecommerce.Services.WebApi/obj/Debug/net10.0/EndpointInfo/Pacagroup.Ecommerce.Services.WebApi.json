      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Registra un nuevo usuario",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignUpUserCommand"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/SignUpUserCommand"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/SignUpUserCommand"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
